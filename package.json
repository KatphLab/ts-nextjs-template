{
  "name": "ts-nextjs-template",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcruise": "depcruise app src",
    "dupcheck": "jscpd app src",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "danger:ci": "danger ci",
    "check": "yarn format && yarn lint && yarn typecheck && yarn test:ci && yarn depcruise && yarn knip && yarn dupcheck && yarn stryker run",
    "fix": "yarn format && yarn lint:fix && yarn knip:fix"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "danger": "^13.0.7",
    "danger-plugin-yarn": "^1.6.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.2",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "packageManager": "yarn@4.13.0"
}
